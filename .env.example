# Server
PORT=3030
NODE_ENV=development

# Postgres (shared influxcode database — privbook_* tables only)
DB_USER=influx
DB_HOST=localhost
DB_NAME=influxcode
DB_PASSWORD=
DB_PORT=5432

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JS_URL=https://your-instance.clerk.accounts.dev/npm/@clerk/clerk-js@5/dist/clerk.browser.js

# Comma-separated list of origins Clerk will accept tokens from.
# In prod include https://privbook.influxcode.io
CLERK_AUTHORIZED_PARTIES=http://localhost:3030,https://privbook.influxcode.io

# Public base URL for non-image asset links (used in API responses).
PUBLIC_BASE_URL=

# Upload limits
MAX_UPLOAD_MB=12
MAX_IMAGES_PER_POST=10

# S3 — uploaded images go to assets.influxcode.io under the privbook/ prefix
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=assets.influxcode.io
S3_PREFIX=privbook
